{
  "name": "kanban-view",
  "version": "1.0.0",
  "description": "View any markdown file as a kanban board. Headings become lanes, list items become cards. Portable, non-destructive, zero file pollution.",
  "main": "main.js",
  "scripts": {
    "typecheck": "tsc --noemit",
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "lint": "eslint ./src/**/*.{ts,tsx}",
    "lint:fix": "eslint ./src/**/*.{ts,tsx} --fix",
    "prettier": "prettier --write \"./src/**/*.{ts,tsx}\"",
    "clean": "npm run prettier && npm run lint:fix",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "release": "git push && git push --tags",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "test:unit": "vitest run tests/unit",
    "test:unit:parsers": "vitest run tests/unit/parsers",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "Parkis Utama",
  "license": "GPL-3.0",
  "devDependencies": {
    "@codemirror/commands": "6.10.2",
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/box-intersect": "^1.0.0",
    "@types/jsdom": "^28.0.0",
    "@types/mark.js": "^8.11.5",
    "@types/node": "^20.0.0",
    "@types/raf-schd": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^5.8.1",
    "@typescript-eslint/parser": "^5.8.1",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-less": "^1.3.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "jsdom": "^28.1.0",
    "magic-string": "^0.30.10",
    "obsidian": "^1.12.0",
    "obsidian-plugin-cli": "^0.9.0",
    "prettier": "^3.1.1",
    "replace": "^1.2.2",
    "tslib": "^2.6.2",
    "typescript": "^5.8.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@tanstack/match-sorter-utils": "^8.15.1",
    "@tanstack/react-table": "^8.11.2",
    "animated-scroll-to": "^2.2.0",
    "box-intersect": "^1.0.2",
    "choices.js": "9.0.1",
    "classcat": "^5.0.3",
    "colord": "^2.9.3",
    "deepmerge": "^4.2.2",
    "eventemitter3": "^5.0.1",
    "fast-json-patch": "^3.1.0",
    "file-selector": "^0.2.4",
    "immutability-helper": "^3.1.1",
    "immutable-json-patch": "^1.1.2",
    "is-plain-object": "^5.0.0",
    "mark.js": "^8.11.1",
    "mdast": "^3.0.0",
    "mdast-util-from-markdown": "^1.0.2",
    "mdast-util-frontmatter": "^1.0.0",
    "mdast-util-to-markdown": "^1.2.6",
    "mdast-util-to-string": "^3.1.0",
    "micromark-util-character": "^1.1.0",
    "micromark-util-types": "^1.0.1",
    "monkey-around": "^2.1.0",
    "preact": "^10.25.0",
    "react": "npm:@preact/compat",
    "react-colorful": "^5.6.1",
    "react-cool-onclickoutside": "^1.6.1",
    "react-dom": "npm:@preact/compat",
    "react-fast-compare": "^3.2.2",
    "unist-util-visit": "^4.1.0"
  },
  "importSort": {
    ".js, .ts, .tsx": {
      "style": "module-alias",
      "options": {
        "alias": [
          "src"
        ]
      }
    }
  }
}
